---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const rawDate = frontmatter.date ? new Date(frontmatter.date) : null;
const date = rawDate && !Number.isNaN(rawDate.valueOf())
  ? new Intl.DateTimeFormat('en-CA', { dateStyle: 'medium' }).format(rawDate)
  : frontmatter.date;
---
<BaseLayout title={frontmatter.title} description={frontmatter.description ?? 'OwnerLens field note'} current="field-notes">
  <article class="content">
    <p class="eyebrow">Field Note</p>
    <h1>{frontmatter.title}</h1>
    <p class="meta">{date}{frontmatter.updated ? ` · updated ${frontmatter.updated}` : ''}</p>
    {frontmatter.warning && <p class="warning">{frontmatter.warning}</p>}
    <slot />
  </article>
</BaseLayout>
